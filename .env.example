APP_NAME=Jarvis Enterprise Voice Assistant
APP_ENV=development
API_PREFIX=/api/v1
ASSISTANT_NAME=Jarvis
DEFAULT_LOCALE=en-IN
DATABASE_PATH=data/voice_assistant.db
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
JWT_SECRET=replace-with-a-long-random-production-secret
JWT_ISSUER=voice-assistant-platform
JWT_AUDIENCE=voice-assistant-web
ACCESS_TOKEN_MINUTES=120
ENABLE_DESKTOP_ACTIONS=false
MUSIC_DIRECTORY=C:\Users\Public\Music
DEFAULT_USER_EMAIL=admin@example.com
DEFAULT_USER_PASSWORD=admin123
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
